# Токен бота от @BotFather
TG_BOT_TOKEN=123456:ABC-DEF
# ID админов через запятую (узнать у @userinfobot)
TG_ADMIN_IDS=111111111,222222222

# Прокси для обхода блокировки Telegram (если api.telegram.org не킾ступен напрямую).
# Пусто = напрямую / через системный VPN.
# Примеры:
#   TG_PROXY=http://IP:PORT
#   TG_PROXY=http://USER:PASS@IP:PORT
#   TG_PROXY=socks5://IP:PORT      (нужен aiohttp_socks)
TG_PROXY=

# Куда присылать авто-экспорт (chat_id), пусто = отключено
EXPORT_CHAT_ID=
# Интервал авто-экспорта в минутах (0 = отключить)
EXPORT_INTERVAL_MIN=60

# Подключение к БД (те же данные, что и у сайта).
# Если бот запускаешь НЕ на том же сервере, что и сайт —
# host должен быть внешним адресом MySQL, а не localhost.
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=metrostroi
DB_USERNAME=root
DB_PASSWORD=
